node_modules/
dist/
# agent-runner ships as a JS GitHub Action — its bundled dist/ MUST be committed
# (GitHub runs action.yml `main: dist/index.js` as-is, with no build step).
!agent-runner/dist/
!agent-runner/dist/**
build/
.next/
out/
coverage/
*.tsbuildinfo
.env
.env.local
.DS_Store
.idea/
.turbo/
.pnpm-store/
*.log
.devdigest/cache/
clones/
playwright-report/
test-results/
.stryker-tmp/
server/reports/

# emdash worktree config (local)
.emdash.json

# pr-self-review local gate state (per-dev, regenerated each run)
.pr-self-review.json

# skill-creator iteration scratch (benchmarks, grading, blind-eval snapshots)
.claude/skills/*-workspace/
